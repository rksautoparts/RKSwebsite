# ── Frontend (Vite — baked into build, set in Cloudflare Pages env) ──
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Resend (quote form → rksautopart@gmail.com) ──
# Local dev: copy to .env
# Production: Cloudflare Dashboard → Pages → Settings → Environment variables (Encrypted)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL="RKS Autopart <noreply@yourdomain.com>"

# Local dev API server only
PORT=3001
