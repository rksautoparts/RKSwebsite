# ── Frontend (Vite — baked into build, set in Cloudflare Pages env) ──
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Supabase (สินค้า / products catalog) ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Resend (quote form → rksautopart@gmail.com) ──
# Local dev: copy this file to .env
# Production: Cloudflare Dashboard → Pages → Settings → Environment variables (Encrypted)
RESEND_API_KEY=re_xxxxxxxxxxxx
# Until you verify your own domain in Resend, you MUST send from onboarding@resend.dev.
# In Resend test mode you can only deliver to the email you signed up with.
RESEND_FROM_EMAIL="RKS Autopart <onboarding@resend.dev>"

# Local dev API server only
PORT=3001
